# Keep the repo in paper mode until you have separately validated strategy,
# sizing, drawdown limits, and broker behavior.
TRADING_MODE=paper

# Required only if you later wire a live broker adapter.
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_PAPER=true

# Required to unlock live mode in the code path. Leave unset by default.
TRADING_LIVE_ACK=

# Runtime account number for the authorized Robinhood Agentic account.
# Do not commit a filled value.
TRADING_ACCOUNT_NUMBER=
